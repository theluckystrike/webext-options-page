{
    "name": "webext-options-page",
    "version": "0.1.0",
    "description": "Pre-built options page framework for Chrome extensions — settings sections, theme support, import/export, search, validation, and responsive layout. Zero dependencies.",
    "author": "Zovo <hello@zovo.one>",
    "license": "MIT",
    "keywords": [
        "chrome-extension",
        "options-page",
        "settings",
        "preferences",
        "chrome-options",
        "manifest-v3",
        "browser-extension",
        "options-ui",
        "settings-page",
        "configuration"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/theluckystrike/webext-options-page.git"
    },
    "homepage": "https://github.com/theluckystrike/webext-options-page",
    "engines": {
        "node": ">=20"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "type": "module",
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "vitest run",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@types/chrome": "^0.0.260",
        "typescript": "^5.3.3",
        "vitest": "^4.0.18"
    }
}
